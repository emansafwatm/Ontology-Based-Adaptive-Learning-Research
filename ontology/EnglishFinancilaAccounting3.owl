            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#IsAccuerd"/>
                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Accrued"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Accrual"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Advanced"/>
        <ace_lexicon:CN_pl>Accrueds</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Accrued</ace_lexicon:CN_sg>
    </owl:Class>
    


