        <owl:disjointWith rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Paid_Expenses"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Prepaid_Expenses"/>
