        <ace_lexicon:CN_pl>Accountses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Accounts</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Accrual -->

    <owl:Class rdf:about="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Accrual">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Accrued"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Advanced"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Financial_Accounting"/>
        <ace_lexicon:CN_pl>Accruals</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Accrual</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Accrued -->

    <owl:Class rdf:about="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Accrued">
