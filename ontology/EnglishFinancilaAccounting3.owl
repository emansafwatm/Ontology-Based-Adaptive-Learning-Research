        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Balance_Nature"/>
                        <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Credit"/>
