                        <owl:onProperty rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Payment"/>
                        <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Not_Happened"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#IsAccuerd"/>
                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Accrued"/>
