                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Payments"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Balance_Nature"/>
