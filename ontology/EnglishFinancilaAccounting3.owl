        <ace_lexicon:CN_sg>AccruedExpenses</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/eman/ontologies/2014/11/EnglishFinancialAccounting#Accrued_Revenue -->

